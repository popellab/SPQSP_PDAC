        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">SIRPa expression on macrophages </body>
        </notes>
      </parameter>
      <parameter id="mw7fad76f8_0e3b_46db_8102_6ee26aa9156d" name="A_Mcell" value="1385.4423602331" units="MWDERIVEDUNIT_micrometer___2" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Surface area of the macrophage </body>
        </notes>
      </parameter>
      <parameter id="mwd7aa1641_8610_4a72_8c8a_4d64278cef19" name="IL10_50_phago" value="270" units="MWBUILTINPREFIX_pico_MWBUILTINUNIT_molarity" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Half-maximal IL-10 level for phagocytosis by macrophage </body>
        </notes>
      </parameter>
      <parameter id="mw31f0facd_a485_4989_aba2_d3b7cd35248c" name="K_M1_phago" value="2" units="dimensionless" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Association coefficient for macrophage and cancer cell </body>
