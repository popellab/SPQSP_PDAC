      <parameter id="mw1d0a5425_448c_41d6_af92_77d327a1c577" name="IL10_50" value="8" units="MWBUILTINPREFIX_pico_MWBUILTINUNIT_molarity" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Half-maximal IL10 level for M1 to M2 polarization / maintaining Treg function / mAPC inhibition (*STAT6 related) </body>
        </notes>
      </parameter>
      <parameter id="mw5cc10257_47fd_49da_bb0b_fa35fde38e81" name="IL12_50" value="15" units="MWBUILTINPREFIX_pico_MWBUILTINUNIT_molarity" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Half-maximal IL-12 level for M2 to M1 macrophage polarization </body>
        </notes>
      </parameter>
      <parameter id="mw25f031a3_2697_4c48_8b7c_a454ca1c59f4" name="IFNg_50" value="1000" units="MWBUILTINPREFIX_pico_MWBUILTINUNIT_molarity" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Half-maximal IFNg level for M2 to M1 macrophage polarization </body>
        </notes>
      </parameter>
      <parameter id="mw70afec96_38f9_4f85_971a_ed59eecd6e20" name="k_M1_phago" value="0.33" units="MWDERIVEDUNIT_1__day" constant="true">
        <notes>
