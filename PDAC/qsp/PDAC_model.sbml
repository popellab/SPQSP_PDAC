        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Volume of a single macrophage cell </body>
        </notes>
      </parameter>
      <parameter id="mw7653458e_614f_4dae_b2d1_734c30747cee" name="kon_CD47_SIRPa" value="0.0625" units="MWDERIVEDUNIT_1__micromolarity_minute_nanometer" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">kon of CD47-SIRPa binding </body>
        </notes>
