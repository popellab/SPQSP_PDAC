      <parameter id="mwb9e71337_680c_4102_aa63_b7fd09e1fb18" name="k_CAF_const" value="2000000" units="MWDERIVEDUNIT_cell__milliliter" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Constitutive PSC density in pancreatic tissue</body>
        </notes>
      </parameter>
      <parameter id="mw03f01aa9_6ec6_4fc7_b44b_a33542c16435" name="k_PSC_to_myCAF" value="0.4" units="MWDERIVEDUNIT_1__day" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">qPSC-&gt;myCAF activation rate (TGFb-driven)</body>
        </notes>
      </parameter>
      <parameter id="mw9621bd6a_c091_4375_b446_972f301fbb15" name="k_PSC_to_iCAF" value="0.2" units="MWDERIVEDUNIT_1__day" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">qPSC-&gt;iCAF activation rate (IL-1-driven)</body>
        </notes>
      </parameter>
      <parameter id="mwde808aa1_a7cc_44ce_9f33_084a6106e3c3" name="k_PSC_to_apCAF" value="0.01" units="MWDERIVEDUNIT_1__day" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">qPSC-&gt;apCAF activation rate (constitutive low)</body>
        </notes>
      </parameter>
      <parameter id="mw30590c79_5d57_4ecb_96e5_1dad19fd9590" name="k_iCAF_to_myCAF" value="0.1" units="MWDERIVEDUNIT_1__day" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">iCAF-&gt;myCAF interconversion (TGFb-driven)</body>
        </notes>
      </parameter>
      <parameter id="mw5be38264_d498_4fb1_b462_1d4ec4c53a10" name="k_myCAF_to_iCAF" value="0.05" units="MWDERIVEDUNIT_1__day" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">myCAF-&gt;iCAF interconversion (IL-1-driven)</body>
        </notes>
      </parameter>
      <parameter id="mwbb546602_e0de_466b_a3e4_44b6de2cdc0e" name="k_myCAF_prolif" value="0.15" units="MWDERIVEDUNIT_1__day" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">myCAF proliferation rate</body>
        </notes>
      </parameter>
      <parameter id="mw2408147c_3f58_4ef3_a7fb_ed247595b73b" name="k_iCAF_prolif" value="0.1" units="MWDERIVEDUNIT_1__day" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">iCAF proliferation rate</body>
        </notes>
      </parameter>
      <parameter id="mwc042046c_74e3_4382_ae2c_96f576694232" name="k_apCAF_prolif" value="0.05" units="MWDERIVEDUNIT_1__day" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">apCAF proliferation rate (lower than iCAF/myCAF)</body>
        </notes>
      </parameter>
      <parameter id="mw10b8fca1_0f9c_4ace_8f47_a19a1a0636c0" name="f_stroma_max" value="3" units="dimensionless" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Max CAF:cancer ratio — logistic carrying capacity for stromal cells</body>
        </notes>
      </parameter>
      <parameter id="mw2bca162f_5d2f_4618_bae6_9f75e0765007" name="k_col_myCAF_sec" value="5e-09" units="MWDERIVEDUNIT_milligram__cell_day" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Collagen secretion rate by myCAFs</body>
        </notes>
      </parameter>
      <parameter id="mw6928f436_d683_4b84_bf90_858ecf11bd68" name="f_col_basal" value="0.5" units="dimensionless" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Basal fraction of collagen secretion (TGFb-independent)</body>
        </notes>
      </parameter>
      <parameter id="mw7304dbc3_3772_4fe4_8a1e_4c4ab65417da" name="TGFb_50_CAF_act" value="0.07" units="MWBUILTINPREFIX_nano_MWBUILTINUNIT_molarity" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">TGFb EC50 for CAF activation and interconversion</body>
        </notes>
      </parameter>
      <parameter id="mwafb76ae7_b737_4850_8745_81eb45c95d59" name="TGFb_50_col_sec" value="0.07" units="MWBUILTINPREFIX_nano_MWBUILTINUNIT_molarity" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">TGFb EC50 for collagen secretion</body>
        </notes>
      </parameter>
      <parameter id="mwe163e8f3_a985_42e9_ac3b_8c63776759d3" name="k_col_deg" value="0.007" units="MWDERIVEDUNIT_1__day" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Constitutive collagen degradation rate</body>
        </notes>
      </parameter>
      <parameter id="mwb82748b9_50e0_49de_9000_bb88155e62e6" name="k_MMP_M2" value="1e-08" units="MWDERIVEDUNIT_milliliter__cell_day" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">M2 macrophage MMP-mediated collagen degradation</body>
        </notes>
      </parameter>
      <parameter id="mw9fd362a3_a070_4731_adca_83e37efcd4cc" name="rho_collagen" value="0.025" units="MWDERIVEDUNIT_gram__milliliter" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Collagen packing density (material constant)</body>
        </notes>
      </parameter>
      <parameter id="mw8549cb82_e646_4ac0_9295_e7541f0f772b" name="phi_collagen" value="0.12" units="dimensionless" constant="false">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Collagen volume fraction (0-1). Primary input for all ECM Hill functions.</body>
        </notes>
      </parameter>
      <parameter id="mw3a272674_990f_4a5f_86d2_664199c143ff" name="k_qpsc_death" value="0.0165" units="MWDERIVEDUNIT_1__day" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Death rate of quiescent PSCs</body>
        </notes>
      </parameter>
      <parameter id="mwfaf32bbb_5af0_4e26_ae23_5072994693be" name="k_iCAF_death" value="0.0165" units="MWDERIVEDUNIT_1__day" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Death rate of iCAFs</body>
        </notes>
      </parameter>
      <parameter id="mwd4218768_ed07_4c63_b0a5_7348f73b508e" name="k_myCAF_death" value="0.0165" units="MWDERIVEDUNIT_1__day" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Death rate of myCAFs</body>
        </notes>
      </parameter>
      <parameter id="mw16780fab_5dfb_46e4_9852_6a3e7fe61f47" name="k_apCAF_death" value="0.0165" units="MWDERIVEDUNIT_1__day" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Death rate of apCAFs</body>
        </notes>
      </parameter>
      <parameter id="mw39602042_d219_4ad3_a050_9d0365837bfd" name="d_pore_ref" value="3.5" units="MWBUILTINPREFIX_micro_MWBUILTINUNIT_meter" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Reference pore size in normal pancreas (Wolf 2013)</body>
        </notes>
      </parameter>
      <parameter id="mw28568e03_5cc4_44bc_8502_3cff7a9d37e2" name="phi_col_ref" value="0.12" units="dimensionless" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Collagen volume fraction in normal pancreas (reference)</body>
        </notes>
      </parameter>
      <parameter id="mw0abd9dcf_a6cc_4b23_a85c_91054130e8d5" name="d_crit_T" value="2.3" units="MWBUILTINPREFIX_micro_MWBUILTINUNIT_meter" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Critical pore diameter for T cell migration arrest (Wolf 2013)</body>
        </notes>
      </parameter>
      <parameter id="mw547a97b9_c73c_4c0e_9ea2_4648fc5f68b9" name="d_crit_APC" value="2.1" units="MWBUILTINPREFIX_micro_MWBUILTINUNIT_meter" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Critical pore diameter for APC migration arrest (podosome/MMP migration)</body>
        </notes>
      </parameter>
      <parameter id="mw64dff5f3_5992_4649_a708_338186926b67" name="n_pore" value="4" units="dimensionless" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Hill coefficient for pore-size exclusion sharpness</body>
        </notes>
      </parameter>
      <parameter id="mw73f6569f_52bb_48f5_a536_0907693b8e94" name="d_pore" value="3.5" units="MWBUILTINPREFIX_micro_MWBUILTINUNIT_meter" constant="false">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Pore size between collagen fibers (decreases with density)</body>
        </notes>
      </parameter>
      <parameter id="mwfaa17fe8_8a36_479e_a2fd_b5c3aee9fb03" name="H_pore_T" value="0" units="dimensionless" constant="false">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Pore-size-based T cell exclusion. 1=fully excluded, 0=free migration.</body>
        </notes>
      </parameter>
      <parameter id="mwec4f3422_173e_4c06_8606_a262ccf3946e" name="H_pore_APC" value="0" units="dimensionless" constant="false">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Pore-size-based APC exclusion. DCs more deformable than T cells.</body>
        </notes>
      </parameter>
      <parameter id="mwb0ae2e57_653f_4288_bc4c_16cfbd6a7c99" name="E_ref" value="1" units="dimensionless" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Reference stiffness at phi_col_ref (~1 kPa, dimensionless)</body>
        </notes>
      </parameter>
      <parameter id="mw53d075aa_b530_453d_9779_99dd4003e9ed" name="n_stiff" value="1.8" units="dimensionless" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Power law exponent for stiffness-collagen relationship</body>
        </notes>
      </parameter>
      <parameter id="mw4e11a13b_a7c6_4c1e_a645_f360295a888c" name="E_50_Texh" value="4" units="dimensionless" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Half-max stiffness for T cell exhaustion</body>
        </notes>
      </parameter>
      <parameter id="mw9424c0d4_eef3_4980_a9fd_23cafa1fb9fa" name="n_Texh" value="1" units="dimensionless" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Hill coefficient for stiffness-mediated T cell exhaustion</body>
        </notes>
      </parameter>
      <parameter id="mw9b767aeb_c221_4906_ac91_c4767416e3ab" name="E_50_fib" value="5" units="dimensionless" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Half-max stiffness for fibroblast mechanotransduction</body>
        </notes>
      </parameter>
      <parameter id="mwcf2c3b60_e80b_4f40_bc6d_2f18027369b8" name="n_fib" value="1" units="dimensionless" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Hill coefficient for stiffness-mediated fibroblast activation</body>
        </notes>
      </parameter>
      <parameter id="mw28d765bb_9ec7_4a30_a1e2_9b75430682b3" name="stiffness" value="1" units="dimensionless" constant="false">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Tissue stiffness (kPa-scaled, dimensionless). Power law of collagen density.</body>
        </notes>
      </parameter>
      <parameter id="mwa14b7e5b_ec88_4a4b_ac7d_6a884148ddc9" name="H_stiff_Texh" value="0" units="dimensionless" constant="false">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Stiffness-mediated T cell exhaustion (chronic mechanosensing, PD-L1)</body>
        </notes>
      </parameter>
      <parameter id="mwe7c2ea93_5c22_4b79_90db_ab1457684ace" name="H_stiff_fib" value="0" units="dimensionless" constant="false">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Stiffness-mediated fibroblast activation (YAP/TAZ mechanotransduction)</body>
        </notes>
      </parameter>
      <parameter id="mw123861c9_9dfd_4627_b237_67b17528c2de" name="phi_col_50_Kmax" value="2" units="dimensionless" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">phi_collagen for 50% carrying capacity reduction. &gt;1 = ECM barrier never reaches half-max, consistent with stroma-depletion worsening PDAC (Rhim 2014, Ozdemir 2014).</body>
        </notes>
      </parameter>
      <parameter id="mw42d7fa38_bfd3_4102_9c58_73764bc3c185" name="K_stiff_niche" value="100000" units="MWUSERUNIT_cell" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Max CAF population sustained by stiff ECM alone (mechanotransduction niche via YAP/TAZ). Allows fibrotic scar persistence post-therapy.</body>
        </notes>
      </parameter>
      <parameter id="mwcc0a11bd_625e_471e_9d84_f4c8a8699fdd" name="k_stroma_support" value="1" units="dimensionless" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Stromal contribution to cancer carrying capacity. Each CAF adds k_stroma_support cells of carrying capacity via nutrient/growth factor provision.</body>
        </notes>
      </parameter>
      <parameter id="mw2afb1a13_3e73_46a6_9c23_eb0dc17fcb58" name="vol_qPSCcell" value="1600" units="MWDERIVEDUNIT_micrometer___3__cell" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Volume of quiescent PSC</body>
        </notes>
      </parameter>
      <parameter id="mw7a9feaa2_5578_4700_831d_a3b976675da3" name="vol_iCAFcell" value="1600" units="MWDERIVEDUNIT_micrometer___3__cell" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Volume of iCAF</body>
        </notes>
      </parameter>
      <parameter id="mw3c15a65b_6f2c_4759_ab3a_714e6854d3da" name="vol_myCAFcell" value="1600" units="MWDERIVEDUNIT_micrometer___3__cell" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Volume of myCAF</body>
        </notes>
      </parameter>
      <parameter id="mw037f2028_a7c6_4a77_998b_0a329bccc578" name="vol_apCAFcell" value="1600" units="MWDERIVEDUNIT_micrometer___3__cell" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Volume of apCAF</body>
        </notes>
      </parameter>
