        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Hill coefficient for CD47/SIRPa inhibition on phagocytosis of cancer cells by macrophages </body>
        </notes>
      </parameter>
      <parameter id="mw0233157d_a259_4df6_b51c_94e35e24560a" name="H_Mac_C" value="0" units="dimensionless" constant="false">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Hill function for overall checkpoint inhibition on phagocytosis of cancer cell by macrophage </body>
