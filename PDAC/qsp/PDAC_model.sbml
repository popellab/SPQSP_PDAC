          <body xmlns="http://www.w3.org/1999/xhtml">Total number of macrophages </body>
        </notes>
      </parameter>
      <parameter id="mwd6363fc0_0791_4424_94db_5e22dbf85646" name="H_IL10" value="1" units="dimensionless" constant="false">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Hill function for IL10-mediated M2-like macrophage polarization / Treg functionality / inhibition on Ag presentaion </body>
        </notes>
      </parameter>
      <parameter id="mw15ab9df5_f22e_4678_9ce3_4a2b2623a2b5" name="H_IL10_phago" value="1" units="dimensionless" constant="false">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Hill function for IL10-mediated inhibition on phagocytosis </body>
        </notes>
      </parameter>
      <parameter id="mwab9e7f0e_b5c4_4a67_8cd2_1bee4740d171" name="H_IL12" value="1" units="dimensionless" constant="false">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Hill function for IL12 </body>
        </notes>
      </parameter>
      <parameter id="mw7e23928c_ca44_4baa_9ff6_a8363aa8a41d" name="H_IL6_M2" value="0" units="dimensionless" constant="false">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Hill function for IL-6 promotion of M2 macrophage polarization</body>
        </notes>
      </parameter>
      <parameter id="mw43b277e9_785b_4a00_aacf_7a80359cc3ea" name="k_CAF_encounter" value="1000000" units="MWDERIVEDUNIT_cell__milliliter_day" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Rate of encountering resident PSCs as tumor expands into pancreas</body>
