      </parameter>
      <parameter id="mw448056f2_e3f7_4a13_868b_8cfdbf043ff2" name="H_PD1_M" value="0" units="dimensionless" constant="false">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Hill function for PD1-mediated inhibition on phagocytosis of cancer cell by macrophage </body>
        </notes>
      </parameter>
      <parameter id="mw637136b2_edcb_4f09_ac2f_14e850231fb3" name="H_SIRPa" value="0" units="dimensionless" constant="false">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">Hill function for SIRPa-mediated inhibition on phagocytosis of cancer cell by macrophage </body>
        </notes>
      </parameter>
      <parameter id="mw341f4d0a_3c3d_4b23_944b_b3980abe085f" name="C_CD47" value="400" units="MWDERIVEDUNIT_molecule__micrometer___2" constant="true">
        <notes>
          <body xmlns="http://www.w3.org/1999/xhtml">CD47 expression on cancer cells </body>
