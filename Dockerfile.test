# ============================================================================
# Test environment for SPQSP_PDAC simulation (multi-stage, ~2GB vs ~12GB)
#
# Build:   docker build -f Dockerfile.test -t pdac-test:latest .
# Run:     docker run --gpus all pdac-test:latest
# Shell:   docker run --gpus all -it pdac-test:latest bash
# HPC:     apptainer run --nv pdac-test.sif
# ============================================================================

# --------------- Stage 1: build ---------------
FROM nvidia/cuda:12.8.0-devel-ubuntu24.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update -qq && \
    apt-get install -y -qq --no-install-recommends \
        cmake g++ git ca-certificates curl \
        libboost-serialization-dev \
    && rm -rf /var/lib/apt/lists/*

# SUNDIALS 7
ARG SUNDIALS_VER=7.6.0
RUN cd /tmp && \
    curl -sL "https://github.com/LLNL/sundials/releases/download/v${SUNDIALS_VER}/sundials-${SUNDIALS_VER}.tar.gz" | tar xz && \
    cd sundials-${SUNDIALS_VER} && \
    cmake -S . -B build \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_SHARED_LIBS=ON \
        -DEXAMPLES_ENABLE_C=OFF \
        -DEXAMPLES_ENABLE_CXX=OFF && \
    cmake --build build --parallel $(nproc) && \
    cmake --install build && \
    rm -rf /tmp/sundials-${SUNDIALS_VER}

COPY PDAC/ /build/PDAC/

ARG CUDA_ARCH="80;90"
WORKDIR /build/PDAC/sim
RUN cmake -S . -B build \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_CUDA_ARCHITECTURES=${CUDA_ARCH} \
        -DSUNDIALS_DIR=/usr/local \
        -DBOOST_ROOT=/usr && \
    cmake --build build --parallel 2 && \
    strip build/bin/pdac

# --------------- Stage 2: runtime (~2GB) ---------------
FROM nvidia/cuda:12.8.0-runtime-ubuntu24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility

RUN apt-get update -qq && \
    apt-get install -y -qq --no-install-recommends \
        python3 python3-pip python3-venv \
        libboost-serialization1.83.0 \
    && rm -rf /var/lib/apt/lists/*

# Copy binary
COPY --from=builder /build/PDAC/sim/build/bin/pdac /sim/build/bin/pdac

# Copy shared libs (SUNDIALS + FLAMEGPU2 runtime)
COPY --from=builder /usr/local/lib/libsundials_* /usr/local/lib/
RUN ldconfig

# Copy test files and param resources
COPY --from=builder /build/PDAC/sim/tests/ /sim/tests/
COPY --from=builder /build/PDAC/sim/resource/ /sim/resource/

# Install uv + test deps
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv
RUN uv venv /sim/.venv && \
    . /sim/.venv/bin/activate && \
    uv pip install pytest lz4
ENV PATH="/sim/.venv/bin:$PATH"

WORKDIR /sim

ENTRYPOINT ["pytest"]
CMD ["tests/", "-v"]
